<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GymPos.Views.SuscripcionPage.CreateSuscripcionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GymPos.Views.SuscripcionPage"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Padding="30">

        <StackPanel Spacing="18">

            <!-- HEADER -->
            <TextBlock Text="Crear Suscripción"
                       FontSize="28"
                       FontWeight="Bold"/>

            <!-- MEMBRESÍA SELECCIONADA -->
            <Border Padding="15"
                    CornerRadius="12"
                    Background="#1F2937">

                <StackPanel>
                    <TextBlock Text="Membresía seleccionada"
                               Foreground="#9CA3AF"/>

                    <TextBlock x:Name="txtMembresia"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>

            </Border>

            <!-- CLIENTE -->
            <StackPanel>
                <TextBlock Text="Cliente" FontWeight="SemiBold"/>

                <ComboBox x:Name="cmbClientes"
                          PlaceholderText="Selecciona un cliente"/>
            </StackPanel>

            <!-- INFO AUTOMÁTICA -->
            <Border Padding="12"
                    CornerRadius="10"
                    Background="#F3F4F6">

                <StackPanel>
                    <TextBlock Text="La suscripción se generará automáticamente:"/>

                    <TextBlock x:Name="txtFechas"
                               Foreground="#6B7280"/>
                </StackPanel>

            </Border>

            <!-- BOTÓN -->
            <Button Content="Crear Suscripción"
                    Click="Button_Click"
                    Background="#2563EB"
                    Foreground="White"
                    Padding="20,10"
                    CornerRadius="8"/>

        </StackPanel>

    </Grid>
</Page>
