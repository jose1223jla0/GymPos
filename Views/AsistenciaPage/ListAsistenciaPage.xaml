<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GymPos.Views.AsistenciaPage.ListAsistenciaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GymPos.Views.AsistenciaPage"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Padding="20">

        <Border 
            CornerRadius="12"
            Padding="12"
            BorderBrush="{ThemeResource AccentAAFillColorSecondaryBrush}"
            BorderThickness="0.5">

            <controls:DataGrid 
                ItemsSource="{Binding SuscripcionesActivas}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                FontSize="13"
                RowHeight="48"
                GridLinesVisibility="Horizontal"
                RowBackground="{ThemeResource AccentAAFillColorDisabled}">
                

                <controls:DataGrid.Columns>

                    <!-- DNI -->
                    <controls:DataGridTextColumn 
                        Header="DNI"
                        FontSize="13"
                        Binding="{Binding Cliente.Dni}"
                        Width="110"/>

                    <!-- NOMBRES -->
                    <controls:DataGridTextColumn 
                        Header="Nombres"
                        FontSize="13"
                        Binding="{Binding Cliente.Nombres}"
                        Width="160"/>

                    <!-- APELLIDOS -->
                    <controls:DataGridTextColumn 
                        Header="Apellidos"
                        FontSize="13"
                        Binding="{Binding Cliente.Apellidos}"
                        Width="160"/>

                    <!-- MEMBRESÍA -->
                    <controls:DataGridTextColumn 
                        Header="Membresía"
                        FontSize="13"
                        Binding="{Binding Membresia.Nombre}"
                        Width="150"/>

            <!--
                    <controls:DataGridTemplateColumn Header="Estado" Width="100">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="Activa"
                                       Foreground="Green"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>-->

                    <!-- ACCIÓN -->
                    <controls:DataGridTemplateColumn 
                        Header="Acción" 
                        Width="130">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <Button Content="Asistencia"
                                    Background="{ThemeResource AccentAcrylicInAppFillColorDefaultBrush}"
                                    HorizontalAlignment="Center"
                                    Padding="8,4"
                                    Command="{Binding DataContext.RegistrarAsistenciaCommand, ElementName=SuscripcionesPage}"
                                    CommandParameter="{Binding IdSuscripcion}"/>

                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                </controls:DataGrid.Columns>

            </controls:DataGrid>

        </Border>

    </Grid>
</Page>
