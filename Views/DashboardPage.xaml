<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GymPos.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
     xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:local="using:GymPos.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Margin="0,20,0,10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ================= KPI ================= -->
            <Grid Grid.Row="0"
              Margin="24,0,24,0"
              ColumnSpacing="12">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- CARD -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">

                    <StackPanel Spacing="6">

                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <SymbolIcon Symbol="People" Foreground="#00CC13"/>
                            <TextBlock Text="Clientes Registrados"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="28"
                                 Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                 FontSize="20"/>
                        </StackPanel>
                    </StackPanel>

                </Border>

                <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">

                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8C7;" Foreground="#00CC13"/>
                            <TextBlock Text="Ingresos hoy"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            
                        </StackPanel>
                        
                        <TextBlock Text="S/ 250.00"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               FontSize="20"/>
                    </StackPanel>

                </Border>

                <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">

                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE762;" Foreground="#00CC13"/>
                            <TextBlock Text="Control de asistencia"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        
                        <TextBlock Text="12"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               FontSize="20"/>
                    </StackPanel>

                </Border>

                <Border Grid.Column="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">

                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE70C;" Foreground="#00CC13"/>
                            <TextBlock Text="Membresías"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        
                        <TextBlock Text="4"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               FontSize="20"/>
                    </StackPanel>

                </Border>

            </Grid>

            <!-- ================= MAIN AREA ================= -->
            <Grid Grid.Row="1"
              Margin="24"
              ColumnSpacing="14">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 📈 MAIN CHART -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="16">

                    <StackPanel>

                        <TextBlock Text="Ingresos vs Asistencia"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                        <Border Height="380"
                            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                            CornerRadius="14"
                            Margin="0,12,0,0">

                            <lvc:CartesianChart Background="Transparent">
                               
                            </lvc:CartesianChart>

                        </Border>

                    </StackPanel>

                </Border>

                <!-- RIGHT PANEL -->
                <StackPanel Grid.Column="1" Spacing="14">

                    <!-- 🥧 PIE -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="16">

                        <StackPanel>

                            <TextBlock Text="Distribución"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   FontWeight="SemiBold"/>

                            <Border Height="180"
                                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                CornerRadius="14"
                                Margin="0,12,0,0">

                                <lvc:PieChart />

                            </Border>

                        </StackPanel>

                    </Border>

                    <!-- ⚡ ACTIVITY -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="16"
                        Height="180">

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Actividad en vivo"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                            FontWeight="SemiBold"/>
                                 <Ellipse x:Name="LiveDot"
                                     HorizontalAlignment="Center"
                                     Width="10"
                                     Height="10"
                                     Fill="Red"
                                     Opacity="1"
                                     VerticalAlignment="Center"/>
                                 
                            </StackPanel>


                            <ListView Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{ThemeResource TextFillColorPrimaryBrush}">

                                <ListViewItem>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE13D;" />
                                        <!-- check-in -->
                                        <TextBlock Text="Check-in: Jose Luis Andrade"/>
                                    </StackPanel>
                                </ListViewItem>

                                <ListViewItem>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE719;" />
                                        <!-- compra -->
                                        <TextBlock Text="Venta: proteína"/>
                                    </StackPanel>
                                </ListViewItem>

                                <ListViewItem>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE77B;" />
                                        <!-- usuario/membresía -->
                                        <TextBlock Text="Membresía nueva"/>
                                    </StackPanel>
                                </ListViewItem>
                            </ListView>
                        </StackPanel>

                    </Border>

                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
