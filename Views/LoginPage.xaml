<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GymPos.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GymPos.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Border Width="400"
            Padding="30"
            CornerRadius="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>

            <Grid RowSpacing="10" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Iniciar sesión"
                       Grid.Row="0"
                       HorizontalAlignment="Center"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" 
                        Spacing="10" 
                        Grid.Row="1">
                    <FontIcon Glyph="&#xE77B;" />
                    <TextBox x:Name="UserTextBox" 
                         PlaceholderText="Usuario" Width="300"/>
                </StackPanel>


                <StackPanel Orientation="Horizontal" 
                        Spacing="10" 
                        Grid.Row="2" 
                        Margin="0,10,0,0">
                    <FontIcon Glyph="&#xE72E;" />
                    <PasswordBox x:Name="PasswordBox" 
                             PlaceholderText="Contraseña" Width="300"/>
                </StackPanel>


                <Button Content="Ingresar"
                    Grid.Row="3"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="10"
                    Margin="0,20,0,0"
                    Click="Button_Click"
                    HorizontalAlignment="Stretch">
                </Button>

                <StackPanel Grid.Row="4">
                    <TextBlock HorizontalAlignment="Center"
                           Margin="5">
                 <Hyperlink Click="Hyperlink_Click">
                     ¿Olvidaste tu contraseña?
                 </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <InfoBar x:Name="AlertBar"
             HorizontalAlignment="Right"
             IsOpen="False" 
             IsClosable="True" 
             Margin="0,15,0,0"/>
    </Grid>
</Page>
