<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GymPos.Views.MembresiaPage.MembresiaListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GymPos.Views.MembresiaPage"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Margin="10" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Membresía Base"
                   FontSize="16"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

        <GridView ItemsSource="{Binding MembresiaList}"
                  IsItemClickEnabled="True"
                  Padding="0"
                  Margin="10"
                  ItemClick="GridView_ItemClick"
                  Grid.Row="1"
                  SelectionMode="None">

            <GridView.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="15"
                            Padding="20"
                            Width="280"
                            Height="180"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Nombre -->
                            <TextBlock Text="{Binding Nombre}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                            <!-- Sesiones -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C7;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="{Binding Sesiones}"/>
                                    <Run Text=" sesiones"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Precio destacado -->
                            <TextBlock Grid.Row="2"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#1DC253"
                                       VerticalAlignment="Center">
                                <Run Text="S/ "/>
                                <Run Text="{Binding Precio}"/>
                            </TextBlock>

                            <!-- Acción discreta -->
                            <StackPanel Grid.Row="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="6">
                                <TextBlock Text="Seleccionar"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <FontIcon Glyph="&#xE76C;" FontSize="12"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </Grid>

                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
        <TextBlock x:Name="MiTexto" Text="" />
    </Grid>
</Page>
